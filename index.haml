<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Poki - Mainkan Subway Surfers & Lainnya</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Bagian Navigasi -->
    <header class="navbar">
        <div class="logo">🎮 GamePoki</div>
        <nav>
            <a href="#" class="nav-link">Beranda</a>
            <a href="#" class="nav-link">Game Populer</a>
            <a href="#" class="nav-link">Kategori</a>
            <a href="#" class="nav-link">Tentang</a>
        </nav>
    </header>

    <!-- Bagian Utama -->
    <main>
        <!-- Bagian Game Unggulan: Subway Surfers -->
        <section class="featured-game">
            <div class="game-cover">
                <img src="https://upload.wikimedia.org/wikipedia/id/thumb/6/66/Subway_Surfers_logo.svg/1200px-Subway_Surfers_logo.svg.png" alt="Subway Surfers">
                <div class="play-overlay">
                    <button id="playBtn" class="play-btn">▶ Mainkan Sekarang</button>
                </div>
            </div>
            <div class="game-info">
                <h2>Subway Surfers</h2>
                <p class="desc">Lari secepat mungkin, hindari kereta, kumpulkan koin, dan tantang temanmu! Game lari tak berujung paling populer di dunia.</p>
                <div class="stats">
                    <span>⭐ 4.8</span>
                    <span>👾 Lari</span>
                    <span>👫 Semua Usia</span>
                </div>
            </div>
        </section>

        <!-- Daftar Game Lainnya -->
        <section class="game-list">
            <h2>Game Populer Lainnya</h2>
            <div class="game-grid">
                <div class="game-card">
                    <div class="card-img" style="background:#ffd700;">🚗</div>
                    <h3>Hill Climb Racing</h3>
                    <button class="card-play">Mainkan</button>
                </div>
                <div class="game-card">
                    <div class="card-img" style="background:#ff4757;">🏀</div>
                    <h3>Basketball Stars</h3>
                    <button class="card-play">Mainkan</button>
                </div>
                <div class="game-card">
                    <div class="card-img" style="background:#3742fa;">🧩</div>
                    <h3>Block Puzzle</h3>
                    <button class="card-play">Mainkan</button>
                </div>
                <div class="game-card">
                    <div class="card-img" style="background:#2ed573;">⚽</div>
                    <h3>Soccer Skills</h3>
                    <button class="card-play">Mainkan</button>
                </div>
            </div>
        </section>
    </main>

    <!-- Bagian Kaki -->
    <footer>
        <p>&copy; 2026 GamePoki Clone. Semua Hak Dilindungi.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
